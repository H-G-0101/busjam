        <string id="THROWBACK_DESC">
            <en>Returns one item back to the playground.</en>
            <es>Devuelve un objeto al campo de juego.</es>
            <de>Bringe einen Gegenstand zurück auf den Spielplatz.</de>
            <it>Riporta un oggetto sul campo di gioco.</it>
            <fr>Renvoie un objet sur le terrain de jeu.</fr>
            <ru>Возвращает один предмет обратно на игровое поле.</ru>
            <pt>Retorna um objeto ao campo de jogo.</pt>
                    <zh>将一个物品放回场地。</zh>
                    <vi>Trả một vật phẩm về sân.</vi>
            <ko>아이템 하나를 필드로 되돌립니다.</ko>
        </string>

        <string id="WHIRLWIND_DESC">
            <en>Shuffles the items on the playground.</en>
            <es>Reordena los elementos en el campo de juego.</es>
            <de>Ordne die Elemente auf dem Spielfeld neu an.</de>
            <it>Riorganizza gli oggetti sul campo di gioco.</it>
            <fr>Réorganisez les éléments sur le terrain de jeu.</fr>
            <ru>Перемешивает предметы на игровом поле.</ru>
            <pt>Reorganize os elementos no campo de jogo.</pt>
                    <zh>打乱场地上的物品。</zh>
                    <vi>Xáo trộn các vật phẩm trên sân.</vi>
            <ko>필드의 아이템을 섞습니다.</ko>
        </string>

        <string id="MGLASS_DESC">
            <en>Highlights three goal items.</en>
            <es>Destaca tres elementos objetivo.</es>
            <de>Markiert drei Zielgegenstände.</de>
            <it>Evidenzia tre elementi oggettivi.</it>
            <fr>Met en évidence trois éléments objectifs.</fr>
            <ru>Выделяет три целевых предмета.</ru>
            <pt>Destaca três elementos objetivo.</pt>
                    <zh>高亮三个目标物品。</zh>
                    <vi>Làm nổi bật ba vật phẩm mục tiêu.</vi>
            <ko>목표 아이템 3개를 강조합니다.</ko>
        </string>

        <string id="ROCKET_DESC">
            <en>Destroys three non-goal items.</en>
            <es>Destruye tres elementos que no son el objetivo.</es>
            <de>Zerstöre drei Nicht-Ziel Gegenstände.</de>
            <it>Distruggi tre oggetti che non sono un obiettivo.</it>
            <fr>Détruit trois éléments non-objectifs.</fr>
            <ru>Уничтожает три нецелевых предмета.</ru>
            <pt>Destrua três itens não-alvo.</pt>
                    <zh>消除三个非目标物品。</zh>
                    <vi>Phá hủy ba vật phẩm không phải mục tiêu.</vi>
            <ko>목표가 아닌 아이템 3개를 제거합니다.</ko>
        </string>

        <string id="INSTRUCTIONS_PAGE0">
            <en>Tap 3 identical items\nto collect them</en>
            <es>Toca 3 objetos iguales\npara recogerlos</es>
            <de>Tippe auf 3 gleiche\nGegenstände, um sie\neinzusammeln</de>
            <it>Tocca 3 oggetti\nidentici per\nraccoglierli</it>
            <fr>Touchez 3 objets\nidentiques pour\nles collecter</fr>
            <ru>Нажми на 3 одинаковых\nпредмета, чтобы\nсобрать их</ru>
            <pt>Toque em 3 objetos\nidênticos para\ncoletá-los</pt>
                    <zh>点击3个相同物品\n来收集</zh>
                    <vi>Chạm 3 vật giống nhau\nđể thu thập</vi>
            <ko>같은 아이템 3개를 탭하여\n수집하세요</ko>
        </string>

        <string id="INSTRUCTIONS_PAGE1">
            <en>Collect all GOAL items\nto finish the level</en>
            <es>Recoge todos los\nelementos OBJETIVO\npara terminar el nivel</es>
            <de>Sammle alle\nZIEL-Gegenstände ein,\num das Level zu beenden</de>
            <it>Raccogli tutti gli\noggetti OBIETTIVO per\nfinire il livello</it>
            <fr>Collectez tous les\nobjets OBJECTIF pour\nterminer le niveau</fr>
            <ru>Собери все ЦЕЛЕВЫЕ\nпредметы, чтобы\nзакончить уровень</ru>
            <pt>Colete todos os itens\nde OBJETIVO para\nterminar o nível</pt>
                    <zh>收集所有目标物品\n以完成关卡</zh>
                    <vi>Thu thập mọi vật MỤC TIÊU\nđể hoàn thành màn</vi>
            <ko>모든 목표 아이템을 수집해\n레벨을 완료하세요</ko>
        </string>

        <string id="INSTRUCTIONS_PAGE2">
            <en>Collect all of the goals\nbefore TIME is over!</en>
            <es>¡Recoge todos los\nobjetivos antes de\nque acabe el TIEMPO!</es>
            <de>Sammle alle Ziele ein,\nbevor die ZEIT\nabgelaufen ist!</de>
            <it>Raccogli tutti gli\nobiettivi prima che\nil TEMPO finisca!</it>
            <fr>Collectez tous les\nobjectifs avant que le\nTEMPS ne soit écoulé!</fr>
            <ru>Собери все цели,\nпока не закончилось\nВРЕМЯ!</ru>
            <pt>Colete todos os\nobjetivos antes que\no TEMPO acabe!</pt>
                    <zh>在时间结束前\n收集所有目标！</zh>
                    <vi>Thu thập mọi mục tiêu\ntrước khi HẾT GIỜ!</vi>
            <ko>시간이 끝나기 전에\n모든 목표를 수집하세요!</ko>
        </string>

        <string id="WELCOME">
            <en>Welcome!</en>
            <es>¡Bienvenido!</es>
            <de>Willkommen!</de>
            <it>Benvenuti!</it>
            <fr>Bienvenue!</fr>
            <ru>Добро пожаловать!</ru>
            <pt>Bem-vindo!</pt>
                    <zh>欢迎！</zh>
                    <vi>Chào mừng!</vi>
            <ko>환영합니다!</ko>
        </string>

        <string id="WELCOME_MESSAGE">
            <en>Let's learn how to play and make the most out of your adventure.</en>
            <es>Vamos a aprender a jugar y a disfrutar al máximo de tu aventura.</es>
            <de>Lass uns lernen, wie man spielt und das Beste aus deinem Abenteuer macht.</de>
            <it>Impara a giocare e sfrutta al meglio la tua avventura.</it>
            <fr>Apprenez à jouer et tirez le meilleur parti de votre aventure.</fr>
            <ru>Давай научимся играть и получим максимум удовольствия от твоего приключения.</ru>
            <pt>Vamos aprender a jogar e aproveitar ao máximo sua aventura.</pt>
                    <zh>让我们学习如何游玩，充分享受你的冒险。</zh>
                    <vi>Hãy học cách chơi và tận hưởng cuộc phiêu lưu của bạn.</vi>
            <ko>플레이 방법을 배우고 모험을 마음껏 즐겨보세요.</ko>
        </string>

        <string id="MAX">
            <en>Max</en>
            <es>Máximo</es>
            <de>Maximal</de>
            <it>Massimo</it>
            <fr>Max</fr>
            <ru>Макс.</ru>
            <pt>Máximo</pt>
                    <zh>最大</zh>
                    <vi>Tối đa</vi>
            <ko>최대</ko>
        </string>

        <string id="MAX_LEVEL_REACHED">
            <en>You’ve reached the maximum level. Resetting will restart your progress, but you’ll unlock a new set of randomized levels for a fresh challenge.</en>
            <es>Has alcanzado el nivel máximo. Al restablecer, reiniciarás tu progreso, pero desbloquearás un nuevo conjunto de niveles aleatorios para un nuevo desafío.</es>
            <de>Du hast das maximale Level erreicht. Wenn du zurücksetzt, wird dein Fortschritt neu gestartet, aber du schaltest eine neue Reihe zufälliger Level für eine frische Herausforderung frei.</de>
            <it>Hai raggiunto il livello massimo. Il ripristino riavvierà i tuoi progressi, ma sbloccherai un nuovo set di livelli casuali per una nuova sfida.</it>
            <fr>Tu as atteint le niveau maximum. La réinitialisation relancera ta progression, mais tu débloqueras un nouveau lot de niveaux aléatoires pour un nouveau défi.</fr>
            <ru>Вы достигли максимального уровня. Сброс приведет к перезапуску прогресса, но вы откроете новый набор случайных уровней для нового испытания.</ru>
            <pt>Você atingiu o nível máximo. A redefinição reiniciará seu progresso, mas você desbloqueará um novo conjunto de níveis aleatórios para um novo desafio.</pt>
                    <zh>你已达到最高关卡。重置将重新开始你的进度，但你将解锁一组新的随机关卡迎接新挑战。</zh>
                    <vi>Bạn đã đạt cấp tối đa. Đặt lại sẽ khởi động lại tiến trình, nhưng bạn sẽ mở khóa bộ màn ngẫu nhiên mới để thử thách.</vi>
            <ko>최고 레벨에 도달했습니다. 초기화하면 진행 상황이 다시 시작되지만, 새로운 무작위 레벨 세트가 잠금 해제되어 새로운 도전을 즐길 수 있습니다.</ko>
        </string>

